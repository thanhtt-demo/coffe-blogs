# AWS credentials — chọn một trong hai cách:
# Cách 1: AWS Profile (khuyến nghị)
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Cách 2: Direct credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ============================================================
# LLM Provider: bedrock (default) hoặc openai
# ============================================================
LLM_PROVIDER=bedrock

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_ID=gpt-5.4-mini  (default)
# OPENAI_MODEL_ID=gpt-4o-mini   (cheaper)
# OPENAI_MODEL_ID=gpt-4o        (legacy)

# --- Bedrock ---
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# ============================================================
# Unsplash API — lấy ảnh thực tế (không bị 404)
# Đăng ký miễn phí tại: https://unsplash.com/developers
# ============================================================
# UNSPLASH_ACCESS_KEY=
