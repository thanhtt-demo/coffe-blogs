---
import '~/assets/styles/tailwind.css';
import '@fontsource-variable/inter';
import { Icon } from 'astro-icon/components';
---

<!doctype html>
<html lang="vi" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Đăng nhập | Ba Tê Admin</title>
    <style>
      :root {
        --aw-font-sans: 'Inter Variable', sans-serif;
        --aw-color-primary: #18181b;
        --aw-color-text-default: #09090b;
        --aw-color-text-muted: #71717a;
        --aw-color-bg-page: #fafafa;
      }
      html {
        font-family: 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
      }
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>

  <body class="antialiased text-default bg-page tracking-tight min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm px-4">
      <h1 class="text-2xl font-bold text-zinc-900 text-center mb-6 tracking-tight">Ba Tê Admin</h1>

      <div class="bg-white border border-zinc-200 rounded-lg p-6">
        <form id="login-form" class="space-y-4">
          <div>
            <label for="api-key" class="flex items-center gap-1.5 text-sm font-medium text-zinc-700 mb-1.5">
              <Icon name="tabler:lock" class="w-4 h-4" />
              API Key
            </label>
            <input
              id="api-key"
              type="password"
              placeholder="Nhập API key"
              autocomplete="current-password"
              class="w-full px-3 py-2 border border-zinc-300 rounded-md text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none placeholder:text-zinc-400"
            />
          </div>

          <button
            id="login-btn"
            type="submit"
            class="bg-blue-600 text-white w-full px-4 py-2 rounded-md font-medium hover:bg-blue-700 transition-colors duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Đăng nhập
          </button>

          <p id="error-msg" class="text-red-600 text-sm mt-2 hidden">API key không hợp lệ</p>
        </form>
      </div>
    </div>

    <script is:inline>
      const API_BASE = 'http://localhost:8000';

      // Redirect if already authenticated
      if (sessionStorage.getItem('apiKey')) {
        window.location.href = '/admin';
      }

      const form = document.getElementById('login-form');
      const input = document.getElementById('api-key');
      const btn = document.getElementById('login-btn');
      const errorMsg = document.getElementById('error-msg');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const key = input.value.trim();
        if (!key) return;

        // Disable button, show loading
        btn.disabled = true;
        btn.textContent = 'Đang xác thực...';
        btn.classList.add('opacity-75');
        errorMsg.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/auth/verify`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${key}` },
          });

          if (res.ok) {
            const data = await res.json();
            if (data.valid) {
              sessionStorage.setItem('apiKey', key);
              window.location.href = '/admin';
              return;
            }
          }

          // Invalid key
          errorMsg.classList.remove('hidden');
        } catch {
          errorMsg.textContent = 'Không thể kết nối tới server';
          errorMsg.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Đăng nhập';
          btn.classList.remove('opacity-75');
        }
      });
    </script>
  </body>
</html>
