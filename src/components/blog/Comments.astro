---
/**
 * Cusdis comment widget — anonymous comments, no login required.
 * Configure appId and host in src/config.yaml under `ui.cusdis`.
 */
import { UI } from 'astrowind:config';

export interface Props {
  /** Override the page ID used for this comment thread. */
  pageId?: string;
  /** Override the page title shown in the Cusdis dashboard. */
  pageTitle?: string;
}

const cusdis = (UI as Record<string, unknown>).cusdis as { appId?: string; host?: string } | undefined;

const appId = cusdis?.appId ?? '';
const host = cusdis?.host ?? 'https://cusdis.com';

const enabled = !!appId;
const pageUrl = Astro.url.pathname;
const { pageId = pageUrl, pageTitle = '' } = Astro.props;
---

{
  enabled && (
    <section id="comments" class="mx-auto max-w-3xl px-6 mt-12 mb-8">
      <h2 class="text-2xl font-bold mb-6 dark:text-slate-300">Bình luận</h2>
      <div
        id="cusdis_thread"
        data-host={host}
        data-app-id={appId}
        data-page-id={pageId}
        data-page-url={pageUrl}
        data-page-title={pageTitle}
        data-theme="light"
      />
      <script is:inline src={`${host}/js/cusdis.es.js`} async defer />
    </section>
  )
}

<style>
  :global(#cusdis_thread iframe) {
    width: 100% !important;
    min-height: 350px;
  }
</style>
